# Environment files and local secrets. Keep examples for reviewers/demo setup.
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# API exports and local testing collections may contain tokens, old endpoints,
# or proprietary headers. Share sanitized examples in README instead.
postman_collection*.json
*.postman_collection.json
*.postman_environment.json

# Signing keys, certificates, and platform private configuration.
*.jks
*.keystore
*.p12
*.pem
*.key
*.crt
*.cer
*.mobileprovision
*.provisionprofile
android/key.properties
android/local.properties
ios/Runner/GoogleService-Info.plist
android/app/google-services.json

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local NestJS backend runtime artifacts.
backend/node_modules/
backend/dist/
backend/coverage/
backend/.logs/
backend/*.log
backend/.mysql-data/
backend/.mysql-runtime/
backend/public/uploads/
